{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "axeom": ["packages/axeom/src/index.ts"],
      "@axeom/core": ["packages/core/src/index.ts"],
      "@axeom/static": ["packages/plugins/static/src/index.ts"],
      "@axeom/auth": ["packages/plugins/auth/src/index.ts"],
      "@axeom/logger-lib": ["packages/logger/src/index.ts"],
      "@axeom/logger": ["packages/plugins/logger/src/index.ts"],
      "@axeom/cors": ["packages/plugins/cors/src/index.ts"],
      "@axeom/security": ["packages/plugins/security/src/index.ts"],
      "@axeom/rate-limit": ["packages/plugins/rate-limit/src/index.ts"],
      "@axeom/schema": ["packages/schema/src/index.ts"],
      "@axeom/upload": ["packages/plugins/upload/src/index.ts"],
      "@axeom/compression": ["packages/plugins/compression/src/index.ts"],
      "@axeom/ws": ["packages/plugins/ws/src/index.ts"],
      "@axeom/swagger": ["packages/plugins/swagger/src/index.ts"],
      "@axeom/web": ["packages/adapter-web/src/index.ts"],
      "@axeom/client": ["packages/client/src/index.ts"],
      "@axeom/express": ["packages/adapter-express/src/index.ts"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules"]
}
