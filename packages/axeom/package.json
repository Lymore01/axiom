{
  "name": "axeom",
  "version": "0.1.1",
  "type": "module",
  "description": "The weightless framework for heavy performance",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web": {
      "types": "./dist/adapters/web.d.ts",
      "import": "./dist/adapters/web.js",
      "require": "./dist/adapters/web.cjs"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./swagger": {
      "types": "./dist/plugins/swagger.d.ts",
      "import": "./dist/plugins/swagger.js",
      "require": "./dist/plugins/swagger.cjs"
    },
    "./ws": {
      "types": "./dist/plugins/ws.d.ts",
      "import": "./dist/plugins/ws.js",
      "require": "./dist/plugins/ws.cjs"
    }
  },
  "dependencies": {
    "@axeom/core": "workspace:*",
    "@axeom/schema": "workspace:*",
    "@axeom/logger-lib": "workspace:*",
    "@axeom/logger": "workspace:*"
  },
  "peerDependencies": {
    "@axeom/web": "workspace:*",
    "@axeom/express": "workspace:*",
    "@axeom/client": "workspace:*",
    "@axeom/swagger": "workspace:*",
    "@axeom/ws": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@axeom/web": {
      "optional": true
    },
    "@axeom/express": {
      "optional": true
    },
    "@axeom/client": {
      "optional": true
    },
    "@axeom/swagger": {
      "optional": true
    },
    "@axeom/ws": {
      "optional": true
    }
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  }
}
