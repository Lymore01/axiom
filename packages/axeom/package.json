{
  "name": "axiom",
  "version": "1.0.0",
  "type": "module",
  "description": "The weightless framework for heavy performance",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./web": "./src/adapters/web.ts",
    "./express": "./src/adapters/express.ts",
    "./client": "./src/client.ts",
    "./swagger": "./src/plugins/swagger.ts",
    "./ws": "./src/plugins/ws.ts"
  },
  "dependencies": {
    "@axiom/core": "workspace:*",
    "@axiom/schema": "workspace:*",
    "@axiom/logger": "workspace:*"
  },
  "peerDependencies": {
    "@axiom/web": "workspace:*",
    "@axiom/adapter-express": "workspace:*",
    "@axiom/client": "workspace:*",
    "@axiom/swagger": "workspace:*",
    "@axiom/ws": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@axiom/web": {
      "optional": true
    },
    "@axiom/adapter-express": {
      "optional": true
    },
    "@axiom/client": {
      "optional": true
    },
    "@axiom/swagger": {
      "optional": true
    },
    "@axiom/ws": {
      "optional": true
    }
  }
}
