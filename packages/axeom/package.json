{
  "name": "@axeom/framework",
  "version": "0.2.0",
  "type": "module",
  "description": "The weightless framework for heavy performance",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@axeom/core": "workspace:*",
    "@axeom/schema": "workspace:*",
    "@axeom/logger-lib": "workspace:*",
    "@axeom/logger": "workspace:*"
  },
  "peerDependencies": {
    "@axeom/web": "workspace:*",
    "@axeom/express": "workspace:*",
    "@axeom/client": "workspace:*",
    "@axeom/swagger": "workspace:*",
    "@axeom/ws": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@axeom/web": {
      "optional": true
    },
    "@axeom/express": {
      "optional": true
    },
    "@axeom/client": {
      "optional": true
    },
    "@axeom/swagger": {
      "optional": true
    },
    "@axeom/ws": {
      "optional": true
    }
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  }
}
