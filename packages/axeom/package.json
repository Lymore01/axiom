{
  "name": "axeom",
  "version": "1.0.0",
  "type": "module",
  "description": "The weightless framework for heavy performance",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./web": "./src/adapters/web.ts",
    "./express": "./src/adapters/express.ts",
    "./client": "./src/client.ts",
    "./swagger": "./src/plugins/swagger.ts",
    "./ws": "./src/plugins/ws.ts"
  },
  "dependencies": {
    "@axeom/core": "workspace:*",
    "@axeom/schema": "workspace:*",
    "@axeom/logger-lib": "workspace:*"
  },
  "peerDependencies": {
    "@axeom/web": "workspace:*",
    "@axeom/express": "workspace:*",
    "@axeom/client": "workspace:*",
    "@axeom/swagger": "workspace:*",
    "@axeom/ws": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@axeom/web": {
      "optional": true
    },
    "@axeom/express": {
      "optional": true
    },
    "@axeom/client": {
      "optional": true
    },
    "@axeom/swagger": {
      "optional": true
    },
    "@axeom/ws": {
      "optional": true
    }
  }
}
