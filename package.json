{
  "name": "axeom-root",
  "description": "The weightless framework for heavy performance",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Kelly Limo",
    "url": "https://github.com/Lymore01",
    "email": "kellytoroitich89@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "axeom-docs": "turbo dev --filter axeom-docs",
    "dev:node": "turbo dev --filter node-express-example",
    "dev:bun": "turbo dev --filter bun-example",
    "dev:bun-native": "turbo dev --filter bun-native-app",
    "dev:cf": "turbo dev --filter cloudflare-workers-example",
    "dev:deno": "turbo dev --filter deno-example",
    "dev:nextjs": "turbo dev --filter nextjs-example",
    "dev:kitchen-sink": "turbo dev --filter kitchen-sink",
    "build": "turbo build",
    "test": "npx vitest run",
    "test:parity": "pnpm test:parity:bun && pnpm test:parity:node && pnpm test:parity:deno && pnpm test:parity:cf",
    "test:parity:bun": "bun run packages/core/test/parity-check.ts",
    "test:parity:node": "npx tsx packages/core/test/parity-check.ts",
    "test:parity:deno": "deno run --allow-net --allow-env --allow-read --allow-sys --sloppy-imports packages/core/test/parity-check.ts",
    "test:parity:cf": "npx tsx packages/core/test/cf-runner.ts",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.10",
    "@vitest/ui": "^4.1.4",
    "esbuild": "^0.28.0",
    "miniflare": "^4.20260409.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
