{
  "name": "axiom",
  "description": "A framework for building web applications",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Lymore01",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter node-express-example dev",
    "dev:bun": "pnpm --filter bun-example dev",
    "dev:cf": "pnpm --filter cloudflare-workers-example dev",
    "dev:deno": "pnpm --filter deno-example dev",
    "build": "pnpm -r build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.13.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
